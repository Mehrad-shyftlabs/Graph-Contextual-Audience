# Audience Targeting — Environment Variables
# Copy to .env and fill in values. All prefixed with AT_.

# ── Qdrant ────────────────────────────────────────────────────────────────
AT_QDRANT_URL=http://localhost:6333
# AT_QDRANT_API_KEY=

# ── Embedding ─────────────────────────────────────────────────────────────
AT_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── Search tuning ─────────────────────────────────────────────────────────
AT_LAYER0_TOP_K=10
AT_LAYER1_TOP_K=30
AT_LAYER2_TOP_K=10
AT_RERANK_TEXT_WEIGHT=0.7
AT_RERANK_GRAPH_WEIGHT=0.3
AT_USE_NODE2VEC=true

# ── Match quality thresholds ─────────────────────────────────────────────
# Segments below partial_match are filtered out. Labels: "match" or "partial_match".
AT_DEFAULT_MATCH_THRESHOLD=0.7
AT_DEFAULT_PARTIAL_MATCH_THRESHOLD=0.5
# Per-platform overrides (JSON). Example:
# AT_PLATFORM_MATCH_THRESHOLDS={"meta": {"match": 0.75, "partial_match": 0.55}, "tiktok": {"match": 0.8}}

# ── Data paths (build pipeline only) ─────────────────────────────────────
AT_DATA_DIR=data
AT_ENRICHED_DIR=data/enriched

# ── LLM enrichment (build pipeline only) ─────────────────────────────────
# AT_OPENAI_API_KEY=sk-...
AT_OPENAI_MODEL=gpt-4o-mini

# ── API ───────────────────────────────────────────────────────────────────
AT_API_HOST=0.0.0.0
AT_API_PORT=8000
AT_LOG_LEVEL=INFO
